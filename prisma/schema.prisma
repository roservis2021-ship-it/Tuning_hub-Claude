generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]
}

model Vehicle {
  id           String       @id @default(cuid())
  brand        String
  model        String
  generation   String?
  engine       String
  year         Int?
  mileage      Int
  fuelType     FuelType
  transmission Transmission
  nickname     String?
  ownerId      String?
  owner        User?        @relation(fields: [ownerId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum FuelType {
  GASOLINA
  DIESEL
  HIBRIDO
  ELECTRICO
  GLP_GNC
}

enum Transmission {
  MANUAL
  AUTOMATICA
}
